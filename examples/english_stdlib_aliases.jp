// English built-in aliases for practical scripting.

var words = split("hajimu,bridge,language", ",")
push(words, "learning")

print("words: " + join(words, " / "))
print("upper: " + upper("hajimu"))
print("json: " + json_encode({"words": words, "count": len(words)}))
print("base64: " + base64_encode("hajimu"))
print("path: " + path_join("docs", "REFERENCE.md"))
print("regex: " + regex_replace("version 1.3.3", "[0-9]+", "X"))
print("set: " + to_string(set_union(set(1, 2), set(2, 3))))

// 英語 built-in alias の非同期・並列補助プリミティブテスト

var passed = 0
var failed = 0

function check(name, actual, expected):
    if to_string(actual) == to_string(expected) then
        passed += 1
    else:
        failed += 1
        print("X " + name + ": expected=" + to_string(expected) + " actual=" + to_string(actual))
    end
end

function answer():
    return 42
end

function double(x):
    return x * 2
end

function one():
    return 1
end

function two():
    return 2
end

function locked_value():
    return 33
end

function guarded_value():
    return 44
end

function add_one(x):
    return x + 1
end

var task = async_run(answer)
check("async_run id", task > 0, true)
check("task_status known", task_status(task) != "不明", true)
check("await_task result", await_task(task, 2), 42)

var task_a = async_run(one)
var task_b = async_run(two)
var async_results = await_all([task_a, task_b])
check("await_all length", len(async_results), 2)
check("await_all sum", async_results[0] + async_results[1], 3)

var then_task = async_run(answer)
var chained_task = then_do(then_task, add_one)
check("then_do result", await_task(chained_task, 2), 43)

var race_a = async_run(one)
var race_b = async_run(two)
var race_result = race([race_a, race_b])
check("race index valid", race_result["番号"] >= 0 and race_result["番号"] <= 1, true)
check("race result valid", race_result["結果"] == 1 or race_result["結果"] == 2, true)

var parallel_results = parallel_run([one, two, answer])
check("parallel_run length", len(parallel_results), 3)
check("parallel_run sum", parallel_results[0] + parallel_results[1] + parallel_results[2], 45)

var mapped = parallel_map([1, 2, 3], double)
check("parallel_map length", len(mapped), 3)
check("parallel_map values", mapped[0] + mapped[1] + mapped[2], 12)

var mutex = mutex_create()
check("mutex_create", mutex >= 0, true)
check("mutex_exec", mutex_exec(mutex, locked_value), 33)

var semaphore = semaphore_create(1)
check("semaphore_create", semaphore >= 0, true)
check("semaphore_exec", semaphore_exec(semaphore, guarded_value), 44)

var counter = atomic_create(5)
check("atomic_add", atomic_add(counter, 7), 12)
check("atomic_get", atomic_get(counter), 12)
check("atomic_set old", atomic_set(counter, 2), 12)
check("atomic_set new", atomic_get(counter), 2)

var channel = channel_create(3)
check("channel_try_send", channel_try_send(channel, "hello"), true)
check("channel_count", channel_count(channel), 1)
check("channel_try_receive value", channel_try_receive(channel)["値"], "hello")
check("channel_try_receive empty", channel_try_receive(channel)["成功"], false)
check("channel_try_send", channel_try_send(channel, "ok"), true)
check("channel_try_receive value", channel_try_receive(channel)["値"], "ok")
channel_close(channel)

assert(failed == 0, "english_concurrency_aliases failed: " + to_string(failed))
print("english_concurrency_aliases: " + to_string(passed) + " passed")

function check(name, actual, expected):
    if actual == expected then
        print("✓ " + name)
    else:
        print("✗ " + name + ": " + to_string(actual) + " != " + to_string(expected))
        exit_program(1)
    end
end

function check_close(name, actual, expected):
    if abs(actual - expected) < 0.000001 then
        print("✓ " + name)
    else:
        print("✗ " + name + ": " + to_string(actual) + " != " + to_string(expected))
        exit_program(1)
    end
end

var m = matrix([[1, 2], [3, 4]])
check("matrix shape rows", shape(m)[0], 2)
check("matrix shape cols", shape(m)[1], 2)
check("matrix dtype default", dtype(m), "f64")
var mi32 = astype(matrix([[1.9, 2.1], [0, -3.8]]), "i32")
check("matrix dtype i32", dtype(mi32), "i32")
check("matrix dtype i32 cast", matrix_get(mi32, 0, 0), 1)
check("matrix dtype row preserve", dtype(matrix_row(mi32, 1)), "i32")
check("matrix logical nbytes", nbytes(mi32), 16)
check("matrix storage bytes", storage_bytes(mi32), 16)
var mbool = astype(matrix([[0, 2], [-1, 0]]), "bool")
check("matrix dtype bool", dtype(mbool), "bool")
check("matrix dtype bool cast", matrix_get(mbool, 0, 1) + matrix_get(mbool, 1, 0), 2)
check("matrix get", matrix_get(m, 1, 0), 3)
check("matrix row vector", m[1][0], 3)
check("matrix_row", matrix_row(m, 1)[1], 4)
check("matrix_column", matrix_column(m, 0)[1], 3)

matrix_set(m, 0, 1, 9)
check("matrix set", matrix_get(m, 0, 1), 9)
check("matrix to_array", to_array(m)[0][1], 9)

var t = transpose(m)
check("transpose rows", shape(t)[0], 2)
check("transpose value", matrix_get(t, 1, 0), 9)

var a = matrix([[1, 2, 3], [4, 5, 6]])
var b = matrix([[1, 2], [3, 4], [5, 6]])
var c = matmul(a, b)
check("matmul rows", shape(c)[0], 2)
check("matmul cols", shape(c)[1], 2)
check("matmul value 1", matrix_get(c, 0, 0), 22)
check("matmul value 2", matrix_get(c, 1, 1), 64)
check("matrix add", matrix_get(matrix_add(matrix([[1, 2]]), matrix([[3, 4]])), 0, 1), 6)
check("matrix sub", matrix_get(matrix_sub(matrix([[5, 4]]), matrix([[3, 1]])), 0, 0), 2)
check("matrix scale", matrix_get(matrix_scale(matrix([[2, 3]]), 4), 0, 1), 12)
check("matrix hadamard", matrix_get(matrix_hadamard(matrix([[2, 3]]), matrix([[4, 5]])), 0, 1), 15)

check("identity shape", shape(identity(3))[0], 3)
check("identity value", matrix_get(identity(3), 2, 2), 1)
check("determinant", determinant(matrix([[1, 2], [3, 4]])), -2)
var inv = inverse(matrix([[4, 7], [2, 6]]))
check_close("inverse value 1", matrix_get(inv, 0, 0), 0.6)
check_close("inverse value 2", matrix_get(inv, 0, 1), -0.7)
var solved = solve_linear(matrix([[2, 1], [1, 3]]), vector([1, 2]))
check_close("solve_linear value 1", solved[0], 0.2)
check_close("solve_linear value 2", solved[1], 0.6)

var model = linear_regression(matrix([[0], [1], [2], [3]]), vector([1, 3, 5, 7]))
check_close("linear_regression intercept", model["intercept"], 1)
check_close("linear_regression weight", model["weights"][0], 2)
check_close("predict_linear vector", predict_linear(model, vector([4])), 9)
check_close("predict_linear matrix", predict_linear(model, matrix([[4], [5]]))[1], 11)
var km = kmeans(matrix([[0], [1], [10], [11]]), 2, 5)
check("kmeans label count", len(km["labels"]), 4)
check("kmeans centers shape", shape(km["centers"])[0], 2)
check("knn_predict vector", knn_predict(matrix([[0], [1], [10], [11]]), vector([0, 0, 1, 1]), vector([10.5]), 3), 1)
check("knn_predict matrix", knn_predict(matrix([[0], [1], [10], [11]]), vector([0, 0, 1, 1]), matrix([[0.2], [10.5]]), 1)[1], 1)
var logistic = logistic_regression(matrix([[0], [1], [2], [3]]), vector([0, 0, 1, 1]), 0.5, 200)
check("predict_logistic low", predict_logistic(logistic, vector([0])) < 0.5, true)
check("predict_logistic high", predict_logistic(logistic, vector([3])) > 0.5, true)
check("predict_logistic_class high", predict_logistic_class(logistic, vector([3])), 1)
check("predict_logistic_class matrix", predict_logistic_class(logistic, matrix([[0], [3]]))[1], 1)

check("matrix json", json_encode(matrix([[1, 2], [3, 4]])), "[[1,2],[3,4]]")

var split_result = train_test_split(matrix([[1, 2], [3, 4], [5, 6], [7, 8]]), 0.25)
check("matrix split train count", split_result["train_count"], 3)
check("matrix split test count", split_result["test_count"], 1)
check("matrix split train shape", shape(split_result["train"])[0], 3)
check("matrix split test value", matrix_get(split_result["test"], 0, 1), 8)
var shuffled = train_test_split(matrix([[1], [2], [3], [4]]), 0.5, 123)
check("matrix seeded split shuffled", shuffled["shuffled"], true)
check("matrix seeded split repeat", matrix_get(shuffled["train"], 0, 0), matrix_get(train_test_split(matrix([[1], [2], [3], [4]]), 0.5, 123)["train"], 0, 0))

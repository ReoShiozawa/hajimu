関数 確認(名前, 実際, 期待値):
    もし 実際 == 期待値 なら
        表示("✓ " + 名前)
    それ以外
        表示("✗ " + 名前 + ": " + 文字列化(実際) + " != " + 文字列化(期待値))
        終了(1)
    終わり
終わり

関数 確認近似(名前, 実際, 期待値):
    もし 絶対値(実際 - 期待値) < 0.000001 なら
        表示("✓ " + 名前)
    それ以外
        表示("✗ " + 名前 + ": " + 文字列化(実際) + " != " + 文字列化(期待値))
        終了(1)
    終わり
終わり

変数 v = ベクトル([1, 2, 3, 4])
確認("ベクトル 長さ", 長さ(v), 4)
確認("ベクトル dtype 初期値", データ型(v), "f64")
変数 vi32 = 型変換(ベクトル([1.9, -2.2, 3000000000]), "i32")
確認("ベクトル dtype i32", データ型(vi32), "i32")
確認("ベクトル dtype i32 変換", vi32[0], 1)
確認("ベクトル dtype i32 飽和", vi32[2], 2147483647)
確認("ベクトル dtype サイズ", データ型サイズ(vi32), 4)
確認("ベクトル 論理バイト数", 論理バイト数(vi32), 12)
確認("ベクトル 保存バイト数", 保存バイト数(vi32), 12)
変数 vbool = 型変換(ベクトル([0, 2, -1]), "bool")
確認("ベクトル dtype bool", データ型(vbool), "bool")
確認("ベクトル dtype bool 変換", vbool[0] + vbool[1] + vbool[2], 2)
確認("ベクトル 合計", ベクトル合計(v), 10)
確認("ベクトル 平均", 平均(v), 2.5)
確認("ベクトル 最大", 最大(v), 4)
確認("ベクトル 最小", 最小(v), 1)
確認("ベクトル 分散", 分散(v), 1.25)
確認("ベクトル 分位点", 分位点(v, 0.75), 3.25)
確認("ベクトル 中央値", 中央値(v), 2.5)
確認("ベクトル 内積", 内積(v, v), 30)
確認("ベクトル 共分散", 共分散(v, ベクトル([2, 4, 6, 8])), 2.5)
確認近似("ベクトル 相関", 相関(v, ベクトル([2, 4, 6, 8])), 1)
変数 hist = ヒストグラム(ベクトル([1, 2, 2, 3, 4]), 3)
確認("ベクトル ヒストグラム 件数1", hist["counts"][0], 1)
確認("ベクトル ヒストグラム 件数2", hist["counts"][1], 2)
確認("ベクトル ヒストグラム 件数3", hist["counts"][2], 2)
確認("ベクトル ヒストグラム 境界", 長さ(hist["edges"]), 4)
変数 split_result = 訓練テスト分割(ベクトル([1, 2, 3, 4, 5]), 0.4)
確認("ベクトル 分割 訓練件数", split_result["train_count"], 3)
確認("ベクトル 分割 テスト件数", split_result["test_count"], 2)
確認("ベクトル 分割 訓練", split_result["train"][2], 3)
確認("ベクトル 分割 テスト", split_result["test"][0], 4)
確認近似("評価 MSE", 平均二乗誤差(ベクトル([1, 2, 3]), ベクトル([1, 2, 5])), 1.333333333333)
確認近似("評価 MAE", 平均絶対誤差(ベクトル([1, 2, 3]), ベクトル([1, 2, 5])), 0.666666666666)
確認近似("評価 R2", 決定係数(ベクトル([1, 2, 3]), ベクトル([1, 2, 3])), 1)
確認近似("評価 accuracy", 正解率(ベクトル([1, 0, 1]), ベクトル([1, 0, 0])), 0.6666666666666666)
確認("評価 precision", 適合率(ベクトル([1, 0, 1]), ベクトル([1, 0, 0])), 1)
確認("評価 recall", 再現率(ベクトル([1, 0, 1]), ベクトル([1, 0, 0])), 0.5)
確認近似("評価 F1", F1スコア(ベクトル([1, 0, 1]), ベクトル([1, 0, 0])), 0.6666666666666666)
変数 cm = 混同行列(ベクトル([1, 0, 1, 0]), ベクトル([1, 1, 0, 0]))
確認("評価 混同行列 TN", 行列取得(cm, 0, 0), 1)
確認("評価 混同行列 TP", 行列取得(cm, 1, 1), 1)
変数 normalized = 標準化(ベクトル([1, 2, 3]))
確認("ベクトル 標準化 長さ", 長さ(normalized), 3)
確認近似("ベクトル 標準化 平均", 平均(normalized), 0)
確認近似("ベクトル 標準化 標準偏差", 標準偏差(normalized), 1)
確認近似("ベクトル Zスコア", Zスコア(ベクトル([1, 2, 3]))[2], normalized[2])
確認("ベクトル ノルム L2", ノルム(ベクトル([3, 4])), 5)
確認("ベクトル ノルム L1", ノルム(ベクトル([-3, 4]), 1), 7)
確認("ベクトル 最小最大スケール", 最小最大スケール(ベクトル([10, 20, 30]))[1], 0.5)
確認("ベクトル クリップ 下限", クリップ(ベクトル([-5, 0, 5]), -1, 3)[0], -1)
確認("ベクトル クリップ 上限", クリップ(ベクトル([-5, 0, 5]), -1, 3)[2], 3)
確認("ベクトル スカラー加算", ベクトル加算(v, 1)[0], 2)
確認("ベクトル スカラー乗算", ベクトル乗算(v, 2)[3], 8)
確認("ベクトル 同士加算", ベクトル加算(v, v)[2], 6)
確認("ベクトル 絶対値", ベクトル絶対値(ベクトル([-2, 3]))[0], 2)
確認("ベクトル 平方根", ベクトル平方根(ベクトル([4, 9]))[1], 3)
確認("ベクトル 添字", v[0], 1)
v[0] = 10
確認("ベクトル 添字代入", v[0], 10)
確認("ベクトル 代入後合計", ベクトル合計(v), 19)

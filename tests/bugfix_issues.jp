// バグ修正の回帰テスト
// Issue #28: value_compare 未対応型 / Issue #30: 繰り返し のオーバーフロー対策

表示("=== バグ修正回帰テスト ===")

// -------------------------------------------------------------------
// Issue #28: ソート() が真偽値・配列・型混在でも一貫した順序を返す
// -------------------------------------------------------------------

// 真偽値: 偽(false) < 真(true)
変数 真偽結果 = ソート([真, 偽, 真, 偽])
表明(真偽結果[0] == 偽, "ソート真偽: 先頭は偽")
表明(真偽結果[3] == 真, "ソート真偽: 末尾は真")

// 数値（既存動作の回帰確認）
変数 数値結果 = ソート([3, 1, 2])
表明(数値結果[0] == 1, "ソート数値: [0]==1")
表明(数値結果[2] == 3, "ソート数値: [2]==3")

// 文字列（既存動作の回帰確認）
変数 文字列結果 = ソート(["c", "a", "b"])
表明(文字列結果[0] == "a", "ソート文字列: [0]==a")
表明(文字列結果[2] == "c", "ソート文字列: [2]==c")

// 型混在: 比較器が常に0を返すと順序不定になる問題の回帰確認
// 型番号順で安定したソートになり、要素が落ちない（長さが保たれる）
変数 混在結果 = ソート([3, "a", 1, 真])
表明(長さ(混在結果) == 4, "ソート型混在: 要素が落ちない")

// -------------------------------------------------------------------
// Issue #30: 繰り返し（文字列リピート）の基本動作とエッジケース
// -------------------------------------------------------------------
表明(繰り返し("ab", 3) == "ababab", "繰り返し: 基本")
表明(繰り返し("ab", 0) == "", "繰り返し: 0回は空文字列")
表明(繰り返し("ab", -1) == "", "繰り返し: 負数は空文字列")
表明(繰り返し("", 5) == "", "繰り返し: 空文字列の繰り返し")
表明(繰り返し("あ", 3) == "あああ", "繰り返し: UTF-8")

表示("全テスト通過")

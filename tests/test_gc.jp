# 循環参照テスト
型 ノード:
    初期化(値):
        自分.値 = 値
        自分.次 = 無
    終わり
終わり

関数 循環テスト():
    変数 a = 新規 ノード(1)
    変数 b = 新規 ノード(2)
    a.次 = b
    b.次 = a
    戻す a.値
終わり

i を 0 から 99 繰り返す
    循環テスト()
終わり

表示("循環参照テスト: OK")

関数 クロージャ循環テスト():
    変数 カウンタ = 0
    変数 増加 = 関数():
        カウンタ = カウンタ + 1
        戻す カウンタ
    終わり
    戻す 増加()
終わり

i を 0 から 99 繰り返す
    クロージャ循環テスト()
終わり

表示("クロージャ循環テスト: OK")

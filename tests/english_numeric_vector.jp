function check(name, actual, expected):
    if actual == expected then
        print("✓ " + name)
    else:
        print("✗ " + name + ": " + to_string(actual) + " != " + to_string(expected))
        exit_program(1)
    end
end

function check_close(name, actual, expected):
    if abs(actual - expected) < 0.000001 then
        print("✓ " + name)
    else:
        print("✗ " + name + ": " + to_string(actual) + " != " + to_string(expected))
        exit_program(1)
    end
end

var v = vector([1, 2, 3, 4])
check("vector len", len(v), 4)
check("vector dtype default", dtype(v), "f64")
var vi32 = astype(vector([1.9, -2.2, 3000000000]), "i32")
check("vector dtype i32", dtype(vi32), "i32")
check("vector dtype i32 cast", vi32[0], 1)
check("vector dtype i32 saturate", vi32[2], 2147483647)
check("vector dtype size", dtype_size(vi32), 4)
check("vector logical nbytes", nbytes(vi32), 12)
check("vector storage bytes", storage_bytes(vi32), 12)
var vbool = astype(vector([0, 2, -1]), "bool")
check("vector dtype bool", dtype(vbool), "bool")
check("vector dtype bool cast", vbool[0] + vbool[1] + vbool[2], 2)
check("vector sum", vector_sum(v), 10)
check("vector mean", mean(v), 2.5)
check("vector max", max(v), 4)
check("vector min", min(v), 1)
check("vector variance", variance(v), 1.25)
check("vector quantile", quantile(v, 0.75), 3.25)
check("vector median", median(v), 2.5)
check("vector dot", dot(v, v), 30)
check("vector covariance", covariance(v, vector([2, 4, 6, 8])), 2.5)
check_close("vector correlation", correlation(v, vector([2, 4, 6, 8])), 1)
var hist = histogram(vector([1, 2, 2, 3, 4]), 3)
check("vector histogram count 1", hist["counts"][0], 1)
check("vector histogram count 2", hist["counts"][1], 2)
check("vector histogram count 3", hist["counts"][2], 2)
check("vector histogram edges", len(hist["edges"]), 4)
var split_result = train_test_split(vector([1, 2, 3, 4, 5]), 0.4)
check("vector split train count", split_result["train_count"], 3)
check("vector split test count", split_result["test_count"], 2)
check("vector split train", split_result["train"][2], 3)
check("vector split test", split_result["test"][0], 4)
check_close("metric mse", mse(vector([1, 2, 3]), vector([1, 2, 5])), 1.333333333333)
check_close("metric mae", mae(vector([1, 2, 3]), vector([1, 2, 5])), 0.666666666666)
check_close("metric r2", r2_score(vector([1, 2, 3]), vector([1, 2, 3])), 1)
check_close("metric accuracy", accuracy(vector([1, 0, 1]), vector([1, 0, 0])), 0.6666666666666666)
check("metric precision", precision(vector([1, 0, 1]), vector([1, 0, 0])), 1)
check("metric recall", recall(vector([1, 0, 1]), vector([1, 0, 0])), 0.5)
check_close("metric f1", f1_score(vector([1, 0, 1]), vector([1, 0, 0])), 0.6666666666666666)
var cm = confusion_matrix(vector([1, 0, 1, 0]), vector([1, 1, 0, 0]))
check("metric confusion tn", matrix_get(cm, 0, 0), 1)
check("metric confusion tp", matrix_get(cm, 1, 1), 1)
var normalized = normalize(vector([1, 2, 3]))
check("vector normalize len", len(normalized), 3)
check_close("vector normalize mean", mean(normalized), 0)
check_close("vector normalize std", std(normalized), 1)
check_close("vector z_score", z_score(vector([1, 2, 3]))[2], normalized[2])
check("vector norm l2", norm(vector([3, 4])), 5)
check("vector norm l1", norm(vector([-3, 4]), 1), 7)
check("vector minmax_scale", minmax_scale(vector([10, 20, 30]))[1], 0.5)
check("vector clip lower", clip(vector([-5, 0, 5]), -1, 3)[0], -1)
check("vector clip upper", clip(vector([-5, 0, 5]), -1, 3)[2], 3)
check("vector scalar add", vector_add(v, 1)[0], 2)
check("vector scalar mul", vector_mul(v, 2)[3], 8)
check("vector pair add", vector_add(v, v)[2], 6)
check("vector abs", vector_abs(vector([-2, 3]))[0], 2)
check("vector sqrt", vector_sqrt(vector([4, 9]))[1], 3)
check("is_vector", is_vector(v), true)
check("vector index", v[0], 1)
v[0] = 10
check("vector index assign", v[0], 10)
check("vector sum after assign", vector_sum(v), 19)
check("vector to_array", to_array(v)[0], 10)
vi32[1] = 7.8
check("vector dtype assign cast", vi32[1], 7)

var z = zeros(3)
check("zeros", vector_sum(z), 0)

var o = ones(3)
check("ones", vector_sum(o), 3)

var r = range_vector(0, 5)
check("range_vector len", len(r), 5)
check("range_vector sum", vector_sum(r), 10)
check("vector json", json_encode(vector([1, 2, 3])), "[1,2,3]")
var summary = describe(vector([1, 2, 3, 4]))
check("vector describe count", summary["count"], 4)
check("vector describe mean", summary["mean"], 2.5)

変数 m = 行列([[4, 7], [2, 6]])
変数 b = ベクトル([1, 2])
変数 x = 行列([[0], [1], [2], [3], [4], [5]])
変数 y = ベクトル([1, 3, 5, 7, 9, 11])
変数 total = 0

i を 0 から 999 繰り返す
    total = total + 行列式(m)
    変数 inv = 逆行列(m)
    変数 solved = 線形方程式を解く(m, b)
    変数 model = 線形回帰(x, y)
    total = total + 行列取得(inv, 0, 0) + solved[0] + 線形予測(model, ベクトル([6]))
終わり

表示("linalg_core = " + 文字列化(total))
